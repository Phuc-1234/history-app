enum HierachyState {
  PUBLIC
  PRIVATE
}

model Grade {
  id           Int   @id     
  state       HierachyState   @default(PUBLIC)
  // Relations
  topics       Topic[]
  tests        Test[]
  questions    Question[]

  @@map("grades")
}

model Topic {
  id        Int        @id @default(autoincrement())
  name      String
  position  Int
  gradeId   Int        @map("grade_id")

  // Relations
  grade     Grade      @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
  tests     Test[]
  questions Question[]

  @@map("topics")
}

model Lesson {
  id        Int         @id @default(autoincrement())
  name      String
  summary   String?     @db.Text
  position  Int
  topicId   Int         @map("topic_id")

  // Relations
  topic     Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  sections  Section[]
  tests     Test[]
  questions Question[]
  flashcards Flashcard[]
  videos     Video[]

  @@map("lessons")
}

enum VideoStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model Video {
  id           String   @id @default(uuid())
  lessonId     Int?     @map("lesson_id") 
  lesson       Lesson?   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title        String
  position     Int
  summary      String?     @db.Text
  hlsUrl       String   @map("hls_url") 
  duration     Float?   
  status       VideoStatus   @default(PENDING) 
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("videos")
}

model Section {
  id              Int         @id @default(autoincrement())
  name            String
  summary         String?     @db.Text
  position        Int
  lessonId        Int         @map("lesson_id")
  parentSectionId Int?        @map("parent_section_id")

  // Relations
  lesson        Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  // FIXED HERE: Both must precisely use the matching string name
  parentSection   Section?  @relation("SectionHierarchy", fields: [parentSectionId], references: [id], onDelete: SetNull)
  childSections   Section[] @relation("SectionHierarchy")
  nodes         Node[]
  tests         Test[]
  questions     Question[]
  flashcards    Flashcard[]

  @@map("sections")
}



model Node {
  id        Int         @id @default(autoincrement())
  position  Int
  header    String
  body      String      @db.Text
  imgUrl    String?     @map("img_url")
  sectionId Int         @map("section_id")

  // Relations
  section   Section     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questions Question[]
  flashcards Flashcard[]

  @@map("nodes")
}

model Flashcard {
  id        Int             @id @default(autoincrement())
  frontText String          @db.Text @map("front_text")
  backText  String          @db.Text @map("back_text")
  lessonId  Int?             @map("lesson_id")
  sectionId Int?             @map("section_id")
  nodeId    Int?            @map("node_id")

  // Relations
  lesson         Lesson?          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  section        Section?         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  node           Node?           @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  userFlashcards UserFlashcard[]

  @@map("flashcards")
}

model UserFlashcard {
  id               Int       @id @default(autoincrement())
  remainingReviews Int       @default(2) @map("remaining_reviews")
  position         Int
  frontText        String    @db.Text @map("front_text")
  backText         String    @db.Text @map("back_text")
  userId           String       @map("user_id")
  flashcardId      Int       @map("flashcard_id")
 
  // Relations
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard        Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@map("user_flashcards")
}


model Test {
  id             String         @id @default(uuid())
  isManual       Boolean        @default(false) @map("is_manual")
  isNationalTest Boolean        @default(false) @map("is_national_test")
  questionNumber Int            @map("question_number")
  timeLimit      Int?           @map("time_limit")
  xpReward       Int            @default(0) @map("xp_reward")
  goldReward     Int            @default(0) @map("gold_reward")
  passThreshold  Int            @default(70) @map("pass_threshold")

  // Scoped Links
  gradeId        Int?            @map("grade_id")
  topicId        Int?            @map("topic_id")
  lessonId       Int?            @map("lesson_id")
  sectionId      Int?            @map("section_id")

  // Relations
  grade         Grade?          @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  topic         Topic?          @relation(fields: [topicId], references: [id], onDelete: SetNull)
  lesson        Lesson?         @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  section       Section?        @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  testQuestions TestQuestion[]
  userTestLogs  UserTestLog[]

  @@map("tests")
}
//=================================

enum QuestionType {
  CHOOSE
  FILL
  MATCH
}

model Question {
  id         Int              @id @default(autoincrement())
  type       QuestionType
  difficulty Int              @default(1)
  promptText String           @db.Text @map("prompt_text")

  // Scoped Links
  gradeId    Int?              @map("grade_id")
  topicId    Int?              @map("topic_id")
  lessonId   Int?              @map("lesson_id")
  sectionId  Int?              @map("section_id")
  nodeId     Int?              @map("node_id")

  // Relations
  grade         Grade?            @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  topic         Topic?            @relation(fields: [topicId], references: [id], onDelete: SetNull)
  lesson        Lesson?           @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  section       Section?          @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  node          Node?            @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  testQuestions TestQuestion[]
  answers       QuestionAnswer[]
  userAnswerLogs  UserAnswerLog[]

  @@map("questions")
}

model QuestionAnswer {
  id            Int      @id @default(autoincrement())
  content       String   @db.Text
  isCorrect     Boolean?  @map("is_correct")
  leftText      String?  @map("left_text")
  rightText     String?  @map("right_text")
  correctAnswer String?  @map("correct_answer") @db.Text
  questionId    Int      @map("question_id")

  // Relations
  question      Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_answers")
}

model TestQuestion {
  testId     String   @map("test_id")
  questionId Int      @map("question_id")
  position   Int

  // Relations
  test     Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([testId, questionId])
  @@map("test_questions")
}



enum UserRole {
  STUDENT
  ADMIN
}

model User {
  id               String              @default(uuid()) @id
  role             UserRole            @default(STUDENT)
  name             String
  email            String              @unique
 
  totalXp          Int                 @default(0) @map("total_xp")
  totalGold        Int                 @default(0) @map("total_gold")
  isHidden         Boolean             @default(false) @map("is_hidden")
 
  profileImgUrl    String?             @map("profile_img_url")
  currentStreak    Int                 @default(0) @map("current_streak")
  highestStreak    Int                 @default(0) @map("highest_streak")
  lastTestPassedAt DateTime?           @map("last_test_passed_at")
  currentTierIndex Int                 @default(1) @map("current_tier_index")

  // Relations
  tier             Tier                @relation(fields: [currentTierIndex], references: [index])
  
  testLogs         UserTestLog[]
  userItems        UserItem[]
  pendingRewards   PendingReward[]
  userFlashcards   UserFlashcard[]

  @@map("users")
}

model Tier {
  index        Int     @id
  name         String
  badgeImgUrl  String? @map("badge_img_url")
  description  String? @db.Text
  xpThreshold  Int     @map("xp_threshold")

  // Relations
  users        User[]

  @@map("tiers")
}




model UserTestLog {
  id            String          @id @default(uuid())
  score         Int
  startedAt     DateTime        @default(now()) @map("started_at")
  submittedAt   DateTime?       @map("submitted_at")
  isPassed      Boolean         @map("is_passed")
  goldEarned    Int             @default(0) @map("gold_earned")
  xpEarned      Int             @default(0) @map("xp_earned")
  attemptNumber Int             @map("attempt_number")
  testId        String          @map("test_id")
  userId        String          @map("user_id")

  // Relations
  test          Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  answerLogs    UserAnswerLog[]

  @@index([userId])
  @@map("user_test_logs")
}

model UserAnswerLog {
  id            Int         @id @default(autoincrement())
  userTestLogId String      @map("user_test_log_id")
  questionId    Int         @map("question_id")
  type          QuestionType
  answerDataJson Json        @map("answer_data_json")

  // Relations
  testLog       UserTestLog @relation(fields: [userTestLogId], references: [id], onDelete: Cascade)
  question      Question    @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@index([userTestLogId])
  @@index([questionId])
  @@map("user_answer_logs")
}

enum ItemType {
  FRAME
  BOOST_XP_TIME
  BOOST_GOLD_TIME
  BOOST_XP_PASS
  BOOST_GOLD_PASS
}

model Item {
  id                Int               @id @default(autoincrement())
  cost              Int?               @default(0)
  isConsumable      Boolean           @map("is_consumable")
  isPurchaseable    Boolean           @map("is_purchaseable")
  imgUrl            String?           @map("img_url")
  description       String?           @db.Text
  type              ItemType
  value             Float?             
  testLimit         Int?              @map("test_limit")
  timeLimit         Int?              @map("time_limit")

  // Relations
  userItems         UserItem[]
  pendingRewards    PendingReward[]
  milestoneRewards  MilestoneReward[]

  @@map("items")
}

model UserItem {
  userId     String      @map("user_id")
  itemId     Int       @map("item_id")
  quantity   Int       @default(1)
  isActive   Boolean   @default(false) @map("is_active")
  activateAt DateTime? @map("activate_at")

  // Relations
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  item       Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@map("user_items")
}

enum RewardSourceType {
  STREAK
  TIER
}

model PendingReward {
  id           Int      @id @default(autoincrement())
  goldAmount   Int      @default(0) @map("gold_amount")
  xpAmount     Int      @default(0) @map("xp_amount")
  itemQuantity Int      @default(0) @map("item_quantity")
  sourceType   RewardSourceType   @map("source_type")
  sourceValue  Int      @map("source_value")
  isClaimed    Boolean  @default(false) @map("is_claimed")
  userId       String      @map("user_id")
  itemId       Int?     @map("item_id")

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item         Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@map("pending_rewards")
}

model MilestoneReward {
  id             Int   @id @default(autoincrement())
  goldAmount     Int   @default(0) @map("gold_amount")
  xpAmount       Int   @default(0) @map("xp_amount")
  itemQuantity   Int   @default(1) @map("item_quantity")
  sourceType     RewardSourceType   @map("source_type")
  sourceValue    Int   @map("source_value")
  itemId         Int?  @map("item_id")

  // Relations
  item           Item? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@map("milestone_rewards")
}



